PB_SUPERUSER_EMAIL=monitor@example.com
PB_SUPERUSER_PASSWORD=replace-with-a-long-random-password

# Dashboard
FRONTEND_PORT=3000
VPS_NAME=vps-01
TZ=Europe/Paris

# Collecte et conservation
COLLECT_INTERVAL=15s
HEALTH_TIMEOUT=3s
METRICS_RETENTION=168h

# Versions et accès local à l'administration PocketBase
POCKETBASE_VERSION=0.38.2
POCKETBASE_PORT=8090

# Point de montage du disque hôte observé (VPS Linux)
HOST_ROOT_PATH=/
